              "fluent-bit.conf": "[SERVICE]\n    Flush         5\n    Log_Level     info\n    Daemon        off\n\n[INPUT]\n    Name              tail\n    Path              /var/log/nginx/access.log\n    Parser            json\n    Tag               nginx.access\n    Refresh_Interval  5\n\n[OUTPUT]\n    Name  elasticsearch\n    Match nginx.*\n    Host  elasticsearch.logging.svc.cluster.local\n    Port  9200\n    Index nginx-access\n    Type  nginx_access\n",
              "parsers.conf": "[PARSER]\n    Name        json\n    Format      json\n    Time_Key    time\n    Time_Format %Y-%m-%dT%H:%M:%S.%L%z\n"
            },
