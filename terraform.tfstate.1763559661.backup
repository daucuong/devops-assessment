            "binary_data": null,
            "data": {
              "access-log-format": "{\n  \"time\": \"$time_iso8601\",\n  \"remote_addr\": \"$remote_addr\",\n  \"remote_user\": \"$remote_user\",\n  \"request\": \"$request\",\n  \"status\": \"$status\",\n  \"body_bytes_sent\": \"$body_bytes_sent\",\n  \"http_referer\": \"$http_referer\",\n  \"http_user_agent\": \"$http_user_agent\",\n  \"request_length\": \"$request_length\",\n  \"request_time\": \"$request_time\",\n  \"upstream_response_time\": \"$upstream_response_time\",\n  \"upstream_addr\": \"$upstream_addr\",\n  \"upstream_status\": \"$upstream_status\",\n  \"host\": \"$host\",\n  \"request_id\": \"$request_id\"\n}\n",
              "access-log-path": "/var/log/nginx/access.log",
              "add-headers": "ingress-nginx/custom-headers",
              "client-body-timeout": "12",
              "client-header-timeout": "12",
              "client-max-body-size": "50m",
              "enable-underscores-in-headers": "true",
              "health-check-path": "/healthz",
              "keep-alive": "75",
              "keep-alive-requests": "1000",
              "max-worker-connections": "65536",
              "proxy-buffer-size": "128k",
              "proxy-buffers": "4 256k",
              "proxy-busy-buffers-size": "256k",
              "proxy-connect-timeout": "5",
              "proxy-next-upstream-timeout": "5",
              "proxy-read-timeout": "30",
              "proxy-send-timeout": "30",
              "rate-limit": "100",
              "rate-limit-window": "1m",
              "send-timeout": "10",
              "upstream-keepalive-connections": "32",
              "worker-processes": "auto"
            },
